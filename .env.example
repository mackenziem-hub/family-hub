# Family Hub environment variables.
# Copy this file to .env.local and fill in real values (never commit .env.local).
# In production these go in the Vercel project dashboard (Settings > Environment Variables).
# NOTE: every value is .trim()'d on read because Vercel can append a trailing newline.

# --- Supabase (Phase 1) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Claude assistant (Phase 2) ---
ANTHROPIC_API_KEY=

# --- Google Calendar read-only (Phase 2) ---
# Google Calendar > Settings > Integrate calendar > "Secret address in iCal format"
GOOGLE_CALENDAR_ICS_URL=

# --- Google Calendar read+write OAuth (Phase 4) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_CALENDAR_ID=primary       # calendar to read/write; set to a shared family calendar ID if you have one

# --- Fitbit read-only sync (Phase 5) ---
FITBIT_CLIENT_ID=
FITBIT_OAUTH_REDIRECT_URI=
# FITBIT_CLIENT_SECRET=          # only if you register a confidential "Server" app instead of public PKCE

# --- NB events cron (Phase 6) ---
CRON_SECRET=                     # bearer secret for manual runs of /api/cron-nb-events (Vercel Cron uses its own header)

# --- App ---
APP_TIMEZONE=America/Moncton
# CAL_TZ_OFFSET_HOURS=-3        # optional: signed UTC offset for floating ICS times (Atlantic = -3)

# --- Assistant / nutrition (optional, have defaults) ---
# CLAUDE_MODEL=claude-sonnet-4-6
# MEAL_CALORIE_CALIBRATION=1.1  # nudge AI calorie estimates up (models under-estimate)
# STORE_MEAL_PHOTOS=true        # set false to analyze-and-discard meal photos (store only numbers)

# --- Seeding ---
# Real account + kid data (names, emails, passwords, kid profiles) lives in
# family.local.json (gitignored). Copy family.example.json to family.local.json and fill it in,
# then run:  npm run seed && npm run seed:kids && npm run seed:places
